# Crypto Puzzle Game - Environment Variables
# Copy this file to .env and fill in your values

# ==================== SERVER ====================
PORT=3000
NODE_ENV=development

# ==================== SECURITY ====================
ENCRYPTION_KEY=your-32-byte-encryption-key-here-change-in-production
HMAC_SECRET=your-hmac-secret-key-here-change-in-production
SALT=your-random-salt-value-here

# ==================== CORS ====================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ==================== RATE LIMITING ====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10

# ==================== GAME CONFIG ====================
TOTAL_LEVELS=30
REWARD_TOKEN_EXPIRY=86400

# ==================== BINANCE PAYMENT ====================
# Your wallet address for receiving USDT
BINANCE_WALLET_ADDRESS=your-usdt-wallet-address-here

# Network: TRC20 (recommended), ERC20, or BEP20
BINANCE_NETWORK=TRC20

# Optional: Binance API for production (not required for demo)
# BINANCE_API_KEY=your-binance-api-key
# BINANCE_API_SECRET=your-binance-api-secret

# Payment settings
PAYMENT_EXPIRY_MINUTES=15

# ==================== DATABASE (Production) ====================
# DATABASE_URL=postgresql://user:password@localhost:5432/puzzlegame

# ==================== LOGGING ====================
LOG_LEVEL=info
