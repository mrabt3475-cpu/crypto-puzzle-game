# Crypto Puzzle Game - Environment Variables
# ============================================
# IMPORTANT: Copy this to .env and fill in your values
# Never commit .env to GitHub!
# ============================================

# ==================== SERVER ====================
PORT=3000
NODE_ENV=development

# ==================== SECURITY ====================
ENCRYPTION_KEY=your-32-byte-encryption-key-here-change-in-production
HMAC_SECRET=your-hmac-secret-key-here-change-in-production
SALT=your-random-salt-value-here

# ==================== CORS ====================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ==================== RATE LIMITING ====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10

# ==================== GAME CONFIG ====================
TOTAL_LEVELS=30
REWARD_TOKEN_EXPIRY=86400

# ==================== BINANCE PAYMENT (REAL API) ====================
# Get these from: https://www.binance.com/en/my/settings/api-management
# 
# IMPORTANT SECURITY NOTES:
# - Create API key with "Read Only" permissions
# - DO NOT enable withdrawal permissions
# - Add your server IP to IP whitelist
# - NEVER share your API Secret
# - Add these to .env locally, NOT in code!

BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Your USDT wallet address for receiving payments
BINANCE_WALLET_ADDRESS=your_usdt_wallet_address_here

# Network: TRC20 (recommended), ERC20, or BEP20
BINANCE_NETWORK=TRC20

# Payment settings
PAYMENT_EXPIRY_MINUTES=15

# ==================== DATABASE (Production) ====================
# DATABASE_URL=postgresql://user:password@localhost:5432/puzzlegame

# ==================== LOGGING ====================
LOG_LEVEL=info
