PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/puzzle-game

# Security
JWT_SECRET=change-this-super-secret-jwt-key
JWT_REFRESH_SECRET=change-this-refresh-secret-key
ENCRYPTION_KEY=your-64-character-encryption-key-here
REQUEST_SIGNATURE_SECRET=your-request-signature-secret
