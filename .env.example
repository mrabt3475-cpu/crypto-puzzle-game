# Server Configuration
PORT=3000
NODE_ENV=development

# Security Keys (IMPORTANT: Change in production!)
ENCRYPTION_KEY=your-32-byte-encryption-key-here-change-in-production
HMAC_SECRET=your-hmac-secret-key-here-change-in-production
SALT=your-random-salt-value-here

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10

# Game Configuration
TOTAL_LEVELS=30
REWARD_TOKEN_EXPIRY=86400

# ==================== BINANCE PAYMENT CONFIGURATION ====================
# Binance API (for production - optional)
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret

# Your wallet address for receiving payments
BINANCE_WALLET_ADDRESS=your-usdt-wallet-address

# Network: TRC20, ERC20, or BEP20
BINANCE_NETWORK=TRC20

# Payment Settings
PAYMENT_EXPIRY_MINUTES=15
PAYMENT_MIN_CONFIRMATIONS=1

# Logging
LOG_LEVEL=info

# Database (for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/puzzlegame
