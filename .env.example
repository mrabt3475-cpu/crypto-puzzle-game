PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/puzzle-game

# Security - CHANGE THESE IN PRODUCTION!
JWT_SECRET=super-secret-jwt-key-change-in-production-2024
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-production-2024
ENCRYPTION_KEY=your-64-character-encryption-key-here-must-be-exactly-64-chars
REQUEST_SIGNATURE_SECRET=super-secret-request-signature-key-change-me
PUZZLE_SECRET_SALT=puzzle-game-secret-salt-2024-change-this

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Binance Payment (Optional)
BINANCE_MERCHANT_ID=your_merchant_id
BINANCE_API_KEY=your_api_key
BINANCE_API_SECRET=your_api_secret
WEBHOOK_URL=https://yourdomain.com/api/payment/webhook

# Manual Payment
PAYMENT_WALLET=your_trc20_usdt_address

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_password

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
