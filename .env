# Crypto Puzzle Game - Environment Variables
# ============================================
# IMPORTANT: Copy this file to .env and fill in your values
# Never commit .env to GitHub!
# ============================================

# ==================== SERVER ====================
PORT=3000
NODE_ENV=development

# ==================== SECURITY ====================
ENCRYPTION_KEY=your-32-byte-encryption-key-here-change-in-production
HMAC_SECRET=your-hmac-secret-key-here-change-in-production
SALT=your-random-salt-value-here

# ==================== CORS ====================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ==================== RATE LIMITING ====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10

# ==================== GAME CONFIG ====================
TOTAL_LEVELS=30
REWARD_TOKEN_EXPIRY=86400

# ==================== BINANCE PAYMENT (REAL API) ====================
# Your API Key from Binance
BINANCE_API_KEY=oxCoAaST29YRr60ZG7ildjdSkADTwyQy0CHbAcOum3ltVtqshvJ8V7kIwvYD4etg

# Your API Secret - ADD THIS MANUALLY!
# Get it from: https://www.binance.com/en/my/settings/api-management
# IMPORTANT: Never share your API Secret!
BINANCE_API_SECRET=YOUR_API_SECRET_HERE

# Your USDT wallet address for receiving payments
BINANCE_WALLET_ADDRESS=YOUR_USDT_WALLET_ADDRESS_HERE

# Network: TRC20 (recommended), ERC20, or BEP20
BINANCE_NETWORK=TRC20

# Payment settings
PAYMENT_EXPIRY_MINUTES=15

# ==================== DATABASE (Production) ====================
# DATABASE_URL=postgresql://user:password@localhost:5432/puzzlegame

# ==================== LOGGING ====================
LOG_LEVEL=info
